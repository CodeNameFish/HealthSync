<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.healthsync.ui.dashboard.DashboardFragment"
        android:label="Dashboard"/>

    <fragment
        android:id="@+id/logFragment"
        android:name="com.example.healthsync.ui.log.LogFragment"
        android:label="Log Health"/>

    <navigation
        android:id="@+id/profile_nav"
        app:startDestination="@id/profileFragment">

        <fragment
            android:id="@+id/profileFragment"
            android:name="com.example.healthsync.ui.profile.ProfileFragment"
            android:label="Profile">
            <action
                android:id="@+id/action_profileFragment_to_reportViewerFragment"
                app:destination="@id/reportViewerFragment" />
        </fragment>

        <fragment
            android:id="@+id/reportViewerFragment"
            android:name="com.example.healthsync.ui.profile.ReportViewerFragment"
            android:label="Weekly Health Report">
            <argument
                android:name="filePath"
                app:argType="string" />
        </fragment>
    </navigation>

</navigation>